{
  "name": "secondbrain",
  "version": "1.0.0",
  "main": "./index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild:ios": "npx expo prebuild --platform ios --clean",
    "rebuild:ios": "npx expo prebuild --platform ios && open ios/secondbrain.xcworkspace",
    "open:xcode": "open ios/secondbrain.xcworkspace",
    "detox:build:ios": "detox build --configuration ios.sim.release",
    "detox:test:ios": "detox test --configuration ios.sim.release",
    "detox:test:ios:reuse": "detox test --configuration ios.sim.release --reuse"
  },
  "dependencies": {
    "@11labs/client": "^0.2.0",
