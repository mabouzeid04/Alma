    "@expo/vector-icons": "^15.0.3",
    "@google/generative-ai": "^0.24.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "babel-preset-expo": "~54.0.9",
    "date-fns": "^3.6.0",
    "elevenlabs": "^1.59.0",
    "expo": "~54.0.30",
    "expo-audio": "~1.1.1",
    "expo-constants": "~18.0.12",
    "expo-crypto": "~15.0.8",
    "expo-file-system": "~19.0.21",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
