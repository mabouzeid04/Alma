# SecondBrain Environment Configuration

# Google Gemini API Key - Get from https://makersuite.google.com/app/apikey
# Used for: STT, TTS, conversation, embeddings
EXPO_PUBLIC_GEMINI_API_KEY=""

# Optional: Gemini TTS voice name (default: Kore)
# Available: Kore, Charon, Fenrir, Aoede, Puck, Leda, Orus, Zephyr
EXPO_PUBLIC_GEMINI_TTS_VOICE="Kore"

# Optional: xAI Grok API Key - enables grok-4-1-fast-non-reasoning
EXPO_PUBLIC_XAI_API_KEY=""

# Optional: OpenAI API Key - enables GPT-5 mini (and other GPT models)
EXPO_PUBLIC_OPENAI_API_KEY=""

# Optional: Default model preference (gemini | xai | openai) and model id override
# Available models:
# - gemini: gemini-3-flash-preview
# - xai: grok-4-1-fast-non-reasoning
# - openai: gpt-5-mini
EXPO_PUBLIC_PRIMARY_MODEL_PROVIDER="xai"
EXPO_PUBLIC_PRIMARY_MODEL="grok-4-1-fast-non-reasoning"

# Per-task model selection (fallback is Gemini if provider fails)
EXPO_PUBLIC_MEMORY_MODEL_PROVIDER="xai"
EXPO_PUBLIC_MEMORY_MODEL="grok-4-1-fast-non-reasoning"

EXPO_PUBLIC_KNOWLEDGE_MODEL_PROVIDER="xai"
EXPO_PUBLIC_KNOWLEDGE_MODEL="grok-4-1-fast-non-reasoning"

EXPO_PUBLIC_EMBEDDING_MODEL_PROVIDER="gemini"
EXPO_PUBLIC_EMBEDDING_MODEL="text-embedding-004"

EXPO_PUBLIC_INSIGHTS_MODEL_PROVIDER="gemini"
EXPO_PUBLIC_INSIGHTS_MODEL="gemini-2.0-flash"